AUTH_SECRET=change-me-to-a-long-random-secret
BACKEND_BASE_URL=http://127.0.0.1:8000

# CORS 配置：逗号分隔的允许来源
# M2-07：通过 nginx 80 入口回源时 origin 形如 http://127.0.0.1 (无端口)，
# 因此除默认 3000 外还应包含 127.0.0.1 / localhost。
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1,http://localhost
ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000

# OAuth 可选：配置后自动启用按钮
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 前端仅用于按钮可用态展示
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=false
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
