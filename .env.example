LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20

APP_SECRET=change-this-to-a-strong-random-secret
APP_FERNET_KEY=
APP_JWT_ALG=HS256
APP_ENV=development
APP_COOKIE_SECURE=true
APP_COOKIE_SAMESITE=lax

LLM_ADMIN_TOKEN=
ALERTS_INGEST_TOKEN=
ALERTS_INGEST_ALLOWED_CIDRS=127.0.0.1/32,::1/128

# Architecture: bind backend to localhost only
BIND_HOST=127.0.0.1

# WAF Gateway: target app URL (via localhost)
TARGET_URL=http://127.0.0.1:8000

# Honeypot: redirect malicious scanners to fake backend
HONEYPOT_ENABLED=true
HONEYPOT_PORT=8888

# Gateway Rate Limiting (token bucket per IP)
GATEWAY_RATE_LIMIT_WINDOW=60
GATEWAY_RATE_LIMIT_MAX=120
GATEWAY_RATE_LIMIT_BURST=30

# Threat Intelligence (AbuseIPDB)
THREAT_INTEL_ENABLED=false
ABUSEIPDB_API_KEY=
THREAT_INTEL_SCORE_THRESHOLD=50

# Redis (for distributed rate limiting, optional)
REDIS_URL=redis://localhost:6379/0

MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@ai-cybersentinel.local
MAIL_FROM_NAME=AI-CyberSentinel
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_VALIDATE_CERTS=true
