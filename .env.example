# ==============================
# AI CyberSentinel 环境变量模板
# 复制为 .env 并填入真实值
# ==============================

# --- 必需：应用主密钥（fallback） ---
# 生成命令：openssl rand -base64 48
# 当 APP_JWT_SECRET 和 APP_API_KEY_ENCRYPTION_SECRET 未单独设置时，
# JWT 签名密钥和 API Key 加密密钥都会从 APP_SECRET 派生（使用不同 salt）。
APP_SECRET=change-me-to-a-random-48-byte-base64-string

# --- 可选：JWT 签名密钥（推荐独立设置） ---
# 生成命令：openssl rand -base64 48
# 独立设置可与 API Key 加密密钥完全隔离，单密钥泄露不互相影响。
# APP_JWT_SECRET=

# --- 可选：API Key 加密密钥（推荐独立设置） ---
# 生成命令：openssl rand -base64 48
# 用于加密用户保存的 LLM/AbuseIPDB 等第三方 API Key。
# APP_API_KEY_ENCRYPTION_SECRET=

# --- 必需：NextAuth 密钥 ---
# 生成命令：openssl rand -base64 48
AUTH_SECRET=change-me-to-another-random-48-byte-base64-string

# --- 运行环境 ---
APP_ENV=production
DEV_MODE=false

# --- 数据库 ---
# 本地默认仍走 SQLite；Docker / 部署可改成
#   postgresql+psycopg://cybersentinel:cybersentinel@postgres:5432/cybersentinel
# 同步 SQLAlchemy engine 会自动把 sqlite+aiosqlite:// 归一化为 sqlite://。
# 留空时回退到 repo 内 data/app.db。
DATABASE_URL=sqlite:///data/app.db

# --- PostgreSQL (Docker部署时必需) ---
# 生成命令：openssl rand -base64 32
POSTGRES_PASSWORD=change-me-to-a-strong-postgres-password

# --- Redis ---
REDIS_URL=redis://:your-password@redis:6379/0
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# --- LLM / AI 配置 ---
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# --- 邮件服务 (SMTP) ---
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-smtp-auth-code
MAIL_FROM=your-email@qq.com
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_SSL_TLS=true
MAIL_STARTTLS=false

# --- 威胁情报 (可选) ---
THREAT_INTEL_ENABLED=false
ABUSEIPDB_API_KEY=

# --- OAuth (可选) ---
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=false
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth 自动注册（默认启用，生产环境建议禁用）
OAUTH_AUTO_REGISTER=true

# --- CORS 配置 ---
# 多个来源用逗号分隔
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# --- 部署配置 ---
# Docker内部改为 0.0.0.0
BIND_HOST=127.0.0.1

# --- 告警摄入令牌（sniffer等agent使用） ---
# 生成命令：openssl rand -base64 48
ALERTS_INGEST_TOKEN=change-me-to-a-random-token-min-32-chars

# --- 蜜罐 ---
# 生产环境建议禁用，仅在特定安全测试场景下启用
HONEYPOT_ENABLED=false

# --- LLM 安全护栏层 (NVIDIA NeMo Guardrails) ---
# 可选: 启用 NeMo Guardrails (Colang 1.0) 加载 LLM-as-judge 兜底。
# 若 NEMO_GUARDRAILS_ENABLED=false 或 NeMo 装不上, 自动回退到 L1 正则 + L4 OpenAI Moderation。
NEMO_GUARDRAILS_ENABLED=false
NEMO_GUARDRAILS_CONFIG_PATH=server/security/llm_guardrails/config

# 护栏层同步超时(秒)。超时不拦截, 记 audit warning。
# SC-11: 从 5s 收紧到 1.5s(单次 Moderation < 200ms, NeMo LLM-as-judge < 1s 典型)
GUARDRAIL_RAIL_TIMEOUT_S=1.5

# L4 OpenAI Moderation: 复用 LLM_API_KEY(若未单独设置 OPENAI_API_KEY)
# 推荐独立设置,以便轮换不影响其他 OpenAI 调用
OPENAI_API_KEY=

# --- LLM 护栏 MCP 端点认证 (security review SC-1) ---
# /mcp 端点必须配置, 否则会被中间件 401 拒绝。
# 生成命令: openssl rand -base64 32
# 调用方(Claude Code / Cursor / 内部 agent)在 HTTP header 携带:
#   X-Guardrails-Key: <value>
GUARDRAILS_MCP_API_KEY=
