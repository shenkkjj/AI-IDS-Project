# Local runtime artifacts
.gstack/
web-next/.gstack/
.omc/
server/.omc/
web-next/.omc/
.claude/worktrees/

# Secrets and local env
.env
.env.*
!.env.example
web-next/.env.local
web-next/.env.*
!web-next/.env.example

# Runtime data
data/app.db
*.db
backups/

# Build/cache artifacts
__pycache__/
*.pyc
*.tsbuildinfo
.next/
node_modules/
.turbo/
dist/
build/

# Debug/development files (project root only — server/tests/ test files are tracked)
/debug_*.py
/test_*.py
/_*.py
/check_*.py
# Allow tracked test files under server/tests/
!server/tests/**/test_*.py
!server/tests/**/conftest.py
!server/tests/**/corpus/

# Package lock files (track these for apps, ignore for libraries)
# package-lock.json is tracked for this app project
